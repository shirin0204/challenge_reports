---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class="container">
      <header class="site-header">
        <a href="/" class="home-link">チャレンジノート</a>
      </header>
      <slot />
    </main>
  </body>
</html>