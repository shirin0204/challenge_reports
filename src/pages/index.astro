---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const challenges = (await getCollection('challenges'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja'));

const reports = await getCollection('reports');
---

<BaseLayout title="チャレンジ一覧">
  <h1>チャレンジ一覧</h1>

  {challenges.map((challenge) => {
    const challengeReports = reports
      .filter((report) => report.data.challengeId === challenge.data.challengeId && !report.data.draft)
      .sort((a, b) => a.data.day - b.data.day);

    const latest = challengeReports[challengeReports.length - 1];

    return (
      <article class="card">
        <h2>
          <a href={`/${challenge.data.challengeId}`}>{challenge.data.title}</a>
        </h2>
        <p>{challenge.data.description}</p>
        <p class="meta">
          全{challenge.data.totalDays}日 / 公開中 {challengeReports.length}件
          {latest && <> / 最新: {latest.data.publishedAt}</>}
        </p>
      </article>
    );
  })}
</BaseLayout>